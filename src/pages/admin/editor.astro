---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout
  title="图文编辑器 — WinTools"
  description="粘贴微信公众号或网页图文，保留格式并将图片压缩上传到 Cloudflare R2。"
>
  <section class="editor-shell">
    <header class="editor-head">
      <div>
        <p class="eyebrow">内容后台</p>
        <h1>图文编辑器</h1>
      </div>
      <div class="status" id="statusText">等待编辑</div>
    </header>

    <section class="settings-panel">
      <label>
        <span>文章 slug</span>
        <input id="slugInput" type="text" placeholder="file-renamer" autocomplete="off" />
      </label>
      <label>
        <span>图片 CDN 地址</span>
        <input id="imageBaseInput" type="url" value="https://img.winstools.com" />
      </label>
      <label>
        <span>最大宽度</span>
        <input id="maxWidthInput" type="number" value="1400" min="320" max="2560" step="40" />
      </label>
      <label>
        <span>WebP 质量</span>
        <input id="qualityInput" type="number" value="82" min="40" max="95" step="1" />
      </label>
      <div class="setting-actions">
        <button id="localizeBtn" type="button">本地化图片</button>
        <button id="copyHtmlBtn" type="button">复制 HTML</button>
        <button id="logoutBtn" type="button">退出登录</button>
      </div>
    </section>

    <section class="metadata-panel">
      <div class="panel-head">
        <strong>文章信息</strong>
        <span>保存和发布时写入文章元数据</span>
      </div>
      <div class="metadata-grid">
        <label class="wide-field">
          <span>文章标题</span>
          <input id="titleInput" type="text" placeholder="文件批量改名工具 — 三步完成批量重命名" />
        </label>
        <label class="wide-field">
          <span>文章简介</span>
          <textarea id="descriptionInput" rows="3" placeholder="用一两句话概括文章解决的问题"></textarea>
        </label>
        <label>
          <span>分类</span>
          <select id="categoryInput">
            <option>文件处理</option><option>系统优化</option><option>效率工具</option><option>网络工具</option><option>其他</option>
          </select>
        </label>
        <label><span>版本</span><input id="versionInput" type="text" value="v1.0.0" /></label>
        <label><span>文件大小</span><input id="fileSizeInput" type="text" value="约 2 MB" /></label>
        <label><span>兼容系统</span><input id="compatibilityInput" type="text" value="Windows 10 / 11（64位）" /></label>
        <label><span>发布日期</span><input id="publishDateInput" type="date" /></label>
        <label><span>封面 Emoji 兜底</span><input id="coverEmojiInput" type="text" value="🛠" maxlength="8" /></label>
        <label class="wide-field"><span>标签（逗号分隔）</span><input id="tagsInput" type="text" placeholder="免安装, 文件管理, 批量处理" /></label>
        <label class="check-field"><input id="featuredInput" type="checkbox" /><span>设为首页推荐</span></label>
      </div>
    </section>

    <section class="cover-panel">
      <div class="panel-head">
        <strong>文章首图</strong>
        <span>统一裁切为 16:9 WebP 并存储到 R2</span>
      </div>
      <div class="cover-content">
        <div class="cover-preview" id="coverPreview">
          <img id="coverPreviewImage" alt="文章首图预览" hidden />
          <span id="coverPreviewFallback">尚未设置首图</span>
        </div>
        <div class="cover-controls">
          <label>
            <span>首图提示词</span>
            <textarea id="coverPromptInput" rows="8" placeholder="完成文章后点击“生成首图提示词”，生成结果可继续修改"></textarea>
          </label>
          <div class="setting-actions">
            <button id="generateCoverPromptBtn" type="button">生成首图提示词</button>
            <button id="copyCoverPromptBtn" type="button">复制提示词</button>
          </div>
          <label><span>首图地址</span><input id="coverUrlInput" type="url" placeholder="上传后自动填写" readonly /></label>
          <input id="coverFileInput" type="file" accept="image/*" hidden />
          <div class="setting-actions">
            <button id="chooseCoverBtn" type="button">上传生成的图片</button>
            <button id="clearCoverBtn" type="button">清除首图</button>
          </div>
          <p class="cover-hint">上传后会自动居中裁切为 1280 × 720，并压缩为 WebP 存入 R2。</p>
        </div>
      </div>
    </section>

    <section class="publish-panel">
      <div class="panel-head">
        <strong>下载与发布</strong>
        <span>文章会保存到 GitHub，随后由 Cloudflare Pages 自动部署</span>
      </div>
      <div class="publish-content">
        <div class="download-grid">
          <label><span>下载名称</span><input id="downloadNameInput" type="text" value="百度网盘" /></label>
          <label class="download-url"><span>下载地址</span><input id="downloadUrlInput" type="url" placeholder="https://..." /></label>
          <label><span>提取码</span><input id="extractCodeInput" type="text" maxlength="32" placeholder="可选" /></label>
        </div>
        <div class="publish-actions">
          <button id="loadArticleBtn" type="button">载入文章</button>
          <button id="saveDraftBtn" type="button">保存草稿</button>
          <button id="publishArticleBtn" class="primary-button" type="button">正式发布</button>
        </div>
      </div>
    </section>

    <section class="editor-card">
      <textarea id="articleEditor"></textarea>
    </section>

    <section class="queue-panel">
      <div class="queue-head">
        <strong>图片处理状态</strong>
        <span id="imageSummary">尚未处理图片</span>
      </div>
      <div id="imageQueue" class="image-queue"></div>
    </section>

    <section class="output-panel">
      <div class="queue-head">
        <strong>HTML 输出</strong>
        <span>复制到商城后台前可最后检查</span>
      </div>
      <textarea id="htmlOutput" spellcheck="false"></textarea>
    </section>
  </section>
</BaseLayout>

<script is:inline src="/vendor/tinymce/tinymce.min.js"></script>

<script>
  const slugInput = document.getElementById('slugInput');
  const imageBaseInput = document.getElementById('imageBaseInput');
  const maxWidthInput = document.getElementById('maxWidthInput');
  const qualityInput = document.getElementById('qualityInput');
  const localizeBtn = document.getElementById('localizeBtn');
  const copyHtmlBtn = document.getElementById('copyHtmlBtn');
  const logoutBtn = document.getElementById('logoutBtn');
  const statusText = document.getElementById('statusText');
  const imageSummary = document.getElementById('imageSummary');
  const imageQueue = document.getElementById('imageQueue');
  const htmlOutput = document.getElementById('htmlOutput');
  const titleInput = document.getElementById('titleInput');
  const descriptionInput = document.getElementById('descriptionInput');
  const categoryInput = document.getElementById('categoryInput');
  const versionInput = document.getElementById('versionInput');
  const fileSizeInput = document.getElementById('fileSizeInput');
  const compatibilityInput = document.getElementById('compatibilityInput');
  const publishDateInput = document.getElementById('publishDateInput');
  const coverEmojiInput = document.getElementById('coverEmojiInput');
  const tagsInput = document.getElementById('tagsInput');
  const featuredInput = document.getElementById('featuredInput');
  const coverPromptInput = document.getElementById('coverPromptInput');
  const coverUrlInput = document.getElementById('coverUrlInput');
  const coverFileInput = document.getElementById('coverFileInput');
  const generateCoverPromptBtn = document.getElementById('generateCoverPromptBtn');
  const copyCoverPromptBtn = document.getElementById('copyCoverPromptBtn');
  const chooseCoverBtn = document.getElementById('chooseCoverBtn');
  const clearCoverBtn = document.getElementById('clearCoverBtn');
  const coverPreviewImage = document.getElementById('coverPreviewImage');
  const coverPreviewFallback = document.getElementById('coverPreviewFallback');
  const downloadNameInput = document.getElementById('downloadNameInput');
  const downloadUrlInput = document.getElementById('downloadUrlInput');
  const extractCodeInput = document.getElementById('extractCodeInput');
  const loadArticleBtn = document.getElementById('loadArticleBtn');
  const saveDraftBtn = document.getElementById('saveDraftBtn');
  const publishArticleBtn = document.getElementById('publishArticleBtn');

  let imageCounter = 1;
  const imageJobs = [];

  publishDateInput.value = new Date().toISOString().slice(0, 10);
  ensureSession();
  renderCoverPreview();

  localizeBtn.addEventListener('click', async () => {
    const editor = tinymce.get('articleEditor');
    await localizeEditorImages(editor);
  });

  copyHtmlBtn.addEventListener('click', async () => {
    const html = getEditorHtml();
    htmlOutput.value = html;
    await navigator.clipboard.writeText(html);
    setStatus('HTML 已复制');
  });

  logoutBtn.addEventListener('click', async () => {
    await fetch('/api/auth/logout', {
      method: 'POST',
      credentials: 'same-origin',
    });
    window.location.assign('/admin/login/');
  });

  chooseCoverBtn.addEventListener('click', () => coverFileInput.click());

  generateCoverPromptBtn.addEventListener('click', async () => {
    try {
      if (!titleInput.value.trim()) throw new Error('请先填写文章标题');
      generateCoverPromptBtn.disabled = true;
      setStatus('正在生成首图提示词...');
      const response = await fetch('/api/editor/generate-cover-prompt', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        credentials: 'same-origin',
        body: JSON.stringify({
          title: titleInput.value.trim(),
          description: descriptionInput.value.trim(),
          category: categoryInput.value,
          bodyHtml: getEditorHtml(),
        }),
      });
      const data = await response.json().catch(() => ({}));
      if (!response.ok) throw new Error(data.error || '首图提示词生成失败');
      coverPromptInput.value = data.prompt || '';
      setStatus('首图提示词已生成，可修改后复制');
    } catch (error) {
      setStatus(error.message || '首图提示词生成失败');
    } finally {
      generateCoverPromptBtn.disabled = false;
    }
  });

  copyCoverPromptBtn.addEventListener('click', async () => {
    const prompt = coverPromptInput.value.trim();
    if (!prompt) {
      setStatus('请先生成或填写首图提示词');
      return;
    }
    try {
      await navigator.clipboard.writeText(prompt);
      setStatus('首图提示词已复制');
    } catch {
      coverPromptInput.focus();
      coverPromptInput.select();
      setStatus('无法自动复制，已选中提示词，请手动复制');
    }
  });

  coverFileInput.addEventListener('change', async () => {
    const file = coverFileInput.files?.[0];
    if (!file) return;
    try {
      chooseCoverBtn.disabled = true;
      setStatus('正在处理首图...');
      const slug = ensureSlug();
      const compressed = await compressCoverToWebp(file);
      const key = `covers/${slug}/cover-${Date.now()}.webp`;
      coverUrlInput.value = await uploadToR2(compressed, key);
      renderCoverPreview();
      setStatus('首图已上传');
    } catch (error) {
      setStatus(error.message || '首图上传失败');
    } finally {
      chooseCoverBtn.disabled = false;
      coverFileInput.value = '';
    }
  });

  clearCoverBtn.addEventListener('click', () => {
    coverUrlInput.value = '';
    renderCoverPreview();
    setStatus('首图已清除');
  });

  loadArticleBtn.addEventListener('click', async () => {
    try {
      setPublishingState(true);
      const slug = ensureSlug();
      setStatus('正在从 GitHub 载入文章...');
      const response = await fetch(`/api/editor/article?slug=${encodeURIComponent(slug)}`, {
        credentials: 'same-origin',
      });
      const data = await response.json().catch(() => ({}));
      if (!response.ok) throw new Error(data.error || '载入文章失败');
      applyArticleData(data.article);
      setStatus(data.article.draft ? '草稿已载入' : '已发布文章已载入');
    } catch (error) {
      setStatus(error.message || '载入文章失败');
    } finally {
      setPublishingState(false);
    }
  });

  saveDraftBtn.addEventListener('click', () => saveArticle('draft'));
  publishArticleBtn.addEventListener('click', async () => {
    if (!window.confirm('确定正式发布这篇文章吗？发布后 GitHub 会触发 Cloudflare 自动部署。')) return;
    await saveArticle('publish');
  });

  tinymce.init({
    selector: '#articleEditor',
    license_key: 'gpl',
    height: 720,
    menubar: 'file edit view insert format table tools',
    plugins: 'autolink lists link image table code fullscreen wordcount',
    toolbar: 'undo redo | blocks | bold italic underline forecolor backcolor | alignleft aligncenter alignright | bullist numlist | link image table | code fullscreen',
    language: 'zh_CN',
    paste_data_images: true,
    paste_as_text: false,
    convert_urls: false,
    extended_valid_elements: '*[*]',
    valid_children: '+body[style],+body[link],+body[meta]',
    content_style: `
      body { font-family: Arial, "Microsoft YaHei", sans-serif; line-height: 1.75; color: #111827; padding: 18px; }
      img { max-width: 100%; height: auto; }
      table { max-width: 100%; border-collapse: collapse; }
      td, th { border: 1px solid #e5e7eb; padding: 8px; }
    `,
    images_upload_handler: async (blobInfo) => {
      const file = blobInfo.blob();
      const result = await processAndUploadImage(file, blobInfo.filename());
      return result.url;
    },
    setup(editor) {
      editor.on('init', () => {
        setStatus('编辑器已就绪');
      });
      editor.on('PastePostProcess', () => {
        window.setTimeout(() => localizeEditorImages(editor), 250);
      });
      editor.on('change keyup undo redo setcontent', () => {
        htmlOutput.value = getEditorHtml();
      });
    },
  });

  async function localizeEditorImages(editor) {
    if (!editor) return;
    const doc = editor.getDoc();
    const images = Array.from(doc.querySelectorAll('img'));
    let touched = 0;

    for (const img of images) {
      const src = img.getAttribute('src') || '';
      if (!src || isLocalR2Url(src) || img.dataset.winstoolsUploading === 'true') continue;
      if (src.startsWith('data:image/')) {
        img.dataset.winstoolsUploading = 'true';
        try {
          const blob = dataUrlToBlob(src);
          const result = await processAndUploadImage(blob, 'pasted-image.png');
          img.setAttribute('src', result.url);
          img.setAttribute('width', String(result.width));
          img.setAttribute('height', String(result.height));
          img.setAttribute('loading', 'lazy');
          img.setAttribute('decoding', 'async');
          touched += 1;
        } catch (error) {
          addImageJob({ name: 'base64 image', status: 'failed', message: error.message });
        } finally {
          delete img.dataset.winstoolsUploading;
        }
      } else if (/^https?:\/\//i.test(src)) {
        addImageJob({
          name: src,
          status: 'skipped',
          message: '远程图片暂未自动下载；后续将由 Worker 代下载到 R2',
        });
      }
    }

    if (touched > 0) {
      editor.fire('change');
      setStatus(`已本地化 ${touched} 张图片`);
    }
    updateSummary();
  }

  async function processAndUploadImage(file, originalName) {
    const slug = ensureSlug();
    const compressed = await compressToWebp(file);
    const outputName = `${String(imageCounter).padStart(3, '0')}.webp`;
    imageCounter += 1;
    const objectKey = `articles/${slug}/${outputName}`;

    addImageJob({
      name: originalName || outputName,
      status: 'uploading',
      message: `${formatBytes(file.size)} -> ${formatBytes(compressed.blob.size)}`,
      key: objectKey,
    });

    const url = await uploadToR2(compressed.blob, objectKey);
    addImageJob({
      name: outputName,
      status: 'done',
      message: url,
      key: objectKey,
    });
    updateSummary();
    return { url, width: compressed.width, height: compressed.height };
  }

  async function uploadToR2(blob, key) {
    const response = await fetch('/api/editor/upload-image', {
      method: 'POST',
      headers: {
        'Content-Type': 'application/octet-stream',
        'X-Image-Key': key,
      },
      credentials: 'same-origin',
      body: blob,
    });
    const data = await response.json().catch(() => ({}));
    if (!response.ok) throw new Error(data.error || '图片上传失败');
    return data.url;
  }

  async function saveArticle(mode) {
    try {
      setPublishingState(true);
      const article = collectArticleData();
      setStatus(mode === 'publish' ? '正在提交发布...' : '正在保存草稿...');
      const response = await fetch('/api/editor/publish', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        credentials: 'same-origin',
        body: JSON.stringify({ mode, article }),
      });
      const data = await response.json().catch(() => ({}));
      if (!response.ok) throw new Error(data.error || '保存文章失败');
      setStatus(mode === 'publish' ? '发布提交成功，Cloudflare 正在部署' : '草稿已保存到 GitHub');
    } catch (error) {
      setStatus(error.message || '保存文章失败');
    } finally {
      setPublishingState(false);
    }
  }

  function collectArticleData() {
    return {
      slug: ensureSlug(),
      title: titleInput.value.trim(),
      description: descriptionInput.value.trim(),
      category: categoryInput.value,
      version: versionInput.value.trim(),
      fileSize: fileSizeInput.value.trim(),
      compatibility: compatibilityInput.value.trim(),
      publishDate: publishDateInput.value,
      cover: coverUrlInput.value.trim(),
      coverEmoji: coverEmojiInput.value.trim(),
      tags: tagsInput.value.split(/[,，]/).map(tag => tag.trim()).filter(Boolean),
      featured: featuredInput.checked,
      downloadLinks: [{
        name: downloadNameInput.value.trim(),
        url: downloadUrlInput.value.trim(),
        extractCode: extractCodeInput.value.trim(),
      }],
      bodyHtml: getEditorHtml(),
    };
  }

  function applyArticleData(article) {
    slugInput.value = article.slug || '';
    titleInput.value = article.title || '';
    descriptionInput.value = article.description || '';
    categoryInput.value = article.category || '其他';
    versionInput.value = article.version || '';
    fileSizeInput.value = article.fileSize || '';
    compatibilityInput.value = article.compatibility || '';
    publishDateInput.value = article.publishDate || '';
    coverUrlInput.value = article.cover || '';
    coverEmojiInput.value = article.coverEmoji || '';
    tagsInput.value = Array.isArray(article.tags) ? article.tags.join(', ') : '';
    featuredInput.checked = Boolean(article.featured);
    const download = article.downloadLinks?.[0] || {};
    downloadNameInput.value = download.name || '百度网盘';
    downloadUrlInput.value = download.url || '';
    extractCodeInput.value = download.extractCode || '';
    tinymce.get('articleEditor')?.setContent(article.bodyHtml || '');
    htmlOutput.value = article.bodyHtml || '';
    renderCoverPreview();
  }

  function setPublishingState(disabled) {
    loadArticleBtn.disabled = disabled;
    saveDraftBtn.disabled = disabled;
    publishArticleBtn.disabled = disabled;
  }

  async function ensureSession() {
    const response = await fetch('/api/auth/session', { credentials: 'same-origin' });
    if (!response.ok) {
      window.location.assign('/admin/login/?next=/admin/editor/');
      return;
    }
    const data = await response.json().catch(() => ({}));
    if (data.username) setStatus(`已登录：${data.username}`);
  }

  async function compressCoverToWebp(file) {
    const bitmap = await createImageBitmap(file);
    const targetWidth = 1280;
    const targetHeight = 720;
    const sourceRatio = bitmap.width / bitmap.height;
    const targetRatio = targetWidth / targetHeight;
    let sx = 0; let sy = 0; let sw = bitmap.width; let sh = bitmap.height;
    if (sourceRatio > targetRatio) {
      sw = Math.round(bitmap.height * targetRatio);
      sx = Math.round((bitmap.width - sw) / 2);
    } else {
      sh = Math.round(bitmap.width / targetRatio);
      sy = Math.round((bitmap.height - sh) / 2);
    }
    const canvas = document.createElement('canvas');
    canvas.width = targetWidth; canvas.height = targetHeight;
    canvas.getContext('2d').drawImage(bitmap, sx, sy, sw, sh, 0, 0, targetWidth, targetHeight);
    const blob = await new Promise(resolve => canvas.toBlob(resolve, 'image/webp', 0.84));
    bitmap.close?.();
    if (!blob) throw new Error('浏览器无法生成首图 WebP');
    return blob;
  }

  function renderCoverPreview() {
    const url = coverUrlInput.value.trim();
    coverPreviewImage.hidden = !url;
    coverPreviewFallback.hidden = Boolean(url);
    if (url) coverPreviewImage.src = url;
    else coverPreviewImage.removeAttribute('src');
  }

  async function compressToWebp(file) {
    const bitmap = await createImageBitmap(file);
    const maxWidth = Number(maxWidthInput.value) || 1400;
    const quality = Math.min(Math.max(Number(qualityInput.value) || 82, 40), 95) / 100;
    const scale = Math.min(1, maxWidth / bitmap.width);
    const width = Math.max(1, Math.round(bitmap.width * scale));
    const height = Math.max(1, Math.round(bitmap.height * scale));
    const canvas = document.createElement('canvas');
    canvas.width = width;
    canvas.height = height;
    canvas.getContext('2d').drawImage(bitmap, 0, 0, width, height);
    const blob = await new Promise(resolve => canvas.toBlob(resolve, 'image/webp', quality));
    bitmap.close?.();
    if (!blob) throw new Error('浏览器无法生成 WebP 图片');
    return { blob, width, height };
  }

  function ensureSlug() {
    const slug = slugify(slugInput.value);
    if (!slug) throw new Error('请先填写文章 slug');
    slugInput.value = slug;
    return slug;
  }

  function slugify(value) {
    return value
      .trim()
      .toLowerCase()
      .replace(/[^a-z0-9]+/g, '-')
      .replace(/^-+|-+$/g, '')
      .slice(0, 80);
  }

  function dataUrlToBlob(dataUrl) {
    const [meta, content] = dataUrl.split(',');
    const mime = /data:([^;]+)/.exec(meta)?.[1] || 'image/png';
    const binary = atob(content);
    const bytes = new Uint8Array(binary.length);
    for (let i = 0; i < binary.length; i += 1) bytes[i] = binary.charCodeAt(i);
    return new Blob([bytes], { type: mime });
  }

  function isLocalR2Url(url) {
    return url.startsWith(imageBaseInput.value.replace(/\/+$/, ''));
  }

  function getEditorHtml() {
    return tinymce.get('articleEditor')?.getContent({ format: 'html' }) ?? '';
  }

  function addImageJob(job) {
    imageJobs.push({ ...job, time: new Date().toLocaleTimeString('zh-CN') });
    renderQueue();
  }

  function renderQueue() {
    imageQueue.replaceChildren();
    imageJobs.slice(-20).reverse().forEach(job => {
      const row = document.createElement('div');
      row.className = `queue-row ${job.status}`;
      const name = document.createElement('strong');
      name.textContent = job.name;
      const message = document.createElement('span');
      message.textContent = `${job.time} · ${job.message}`;
      row.append(name, message);
      imageQueue.append(row);
    });
  }

  function updateSummary() {
    const done = imageJobs.filter(job => job.status === 'done').length;
    const failed = imageJobs.filter(job => job.status === 'failed').length;
    const skipped = imageJobs.filter(job => job.status === 'skipped').length;
    imageSummary.textContent = `${done} 已上传 / ${failed} 失败 / ${skipped} 远程待处理`;
  }

  function setStatus(text) {
    statusText.textContent = text;
  }

  function formatBytes(bytes) {
    if (!bytes) return '0 KB';
    if (bytes < 1024 * 1024) return `${Math.round(bytes / 1024)} KB`;
    return `${(bytes / 1024 / 1024).toFixed(1)} MB`;
  }
</script>

<style>
  .editor-shell {
    min-height: calc(100vh - var(--nav-h));
    background: var(--bg2);
    padding: 24px;
