---
import { getCoverPresentation } from '../lib/cover-presentation.js';

interface Props {
  slug: string;
  title: string;
  description: string;
  category: string;
  cover?: string;
  coverEmoji?: string;
  publishDate: Date;
  featured?: boolean;
  downloadCount?: number;
  tags?: string[];
  class?: string;
}

const {
  slug,
  title,
  description,
  category,
  cover = '',
  coverEmoji = '🛠',
  publishDate,
  featured = false,
  downloadCount,
  tags = [],
  class: className = '',
} = Astro.props;

const dateStr = publishDate.toLocaleDateString('zh-CN', {
  year: 'numeric', month: '2-digit', day: '2-digit',
}).replace(/\//g, '-');

const coverPresentation = getCoverPresentation({ cover, category, coverEmoji });
---

<a class:list={['tool-card', { featured }, className]} href={`/tools/${slug}`}>
  <div class="card-cover" style={`background:${coverPresentation.background}`}>
    {coverPresentation.image
      ? <img src={coverPresentation.image} alt="" loading="lazy" decoding="async" />
      : <span class="cover-emoji" aria-hidden="true">{coverPresentation.emoji}</span>}
    {featured && <span class="badge badge-new">NEW</span>}
  </div>
  <div class="card-body">
    <div class="card-cat">{category}</div>
    <h2 class="card-title">{title}</h2>
    <p class="card-desc">{description}</p>
    <div class="card-footer">
      <span class="card-date">{dateStr}</span>
      {downloadCount && (
        <span class="card-dl">
          <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/>
            <polyline points="7 10 12 15 17 10"/>
            <line x1="12" y1="15" x2="12" y2="3"/>
          </svg>
          {downloadCount.toLocaleString()} 次
        </span>
      )}
    </div>
  </div>
</a>

<style>
  .tool-card {
    display: flex; flex-direction: column;
    background: var(--bg);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    overflow: hidden;
    text-decoration: none; color: inherit;
    box-shadow: var(--shadow-sm);
    transition: box-shadow 0.2s, transform 0.2s, border-color 0.2s;
  }
  .tool-card:hover {
    box-shadow: var(--shadow-md);
    transform: translateY(-3px);
    border-color: #D1D5DB;
  }
  .card-cover {
    position: relative;
    width: 100%; aspect-ratio: 16/9;
    display: flex; align-items: center; justify-content: center;
  }
  .card-cover img {
    width: 100%;
    height: 100%;
    display: block;
    object-fit: cover;
  }
  .cover-emoji { font-size: 38px; }
  .badge {
    position: absolute; top: 10px; left: 10px;
    font-size: 11px; font-weight: 700;
    padding: 3px 8px; border-radius: 6px;
  }
  .badge-new { background: var(--blue); color: #fff; }
  .card-body {
    padding: 14px 16px 16px;
    flex: 1; display: flex; flex-direction: column;
  }
  .card-cat {
    font-size: 11px; font-weight: 700;
    letter-spacing: 0.04em; text-transform: uppercase;
    color: var(--blue); margin-bottom: 6px;
  }
  .card-title {
    font-family: var(--font-display);
    font-size: 15px; font-weight: 600; line-height: 1.4;
    color: var(--text); margin-bottom: 7px;
    display: -webkit-box;
    -webkit-line-clamp: 2; -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .card-desc {
    font-size: 13px; color: var(--text2); line-height: 1.6; flex: 1;
    display: -webkit-box;
    -webkit-line-clamp: 2; -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .card-footer {
    display: flex; align-items: center; justify-content: space-between;
    margin-top: 12px; padding-top: 10px;
    border-top: 1px solid var(--border);
  }
  .card-date { font-size: 12px; color: var(--text3); }
  .card-dl {
    display: flex; align-items: center; gap: 4px;
    font-size: 12px; color: var(--text3);
  }

  /* Featured: wide card */
  .tool-card.featured {
    flex-direction: row;
    grid-column: span 2;
  }
  .tool-card.featured .card-cover {
    width: 42%; aspect-ratio: auto;
    flex-shrink: 0;
  }
  .tool-card.featured .cover-emoji { font-size: 56px; }
  .tool-card.featured .card-title { font-size: 17px; }
  .tool-card.featured .card-desc { -webkit-line-clamp: 3; }

  @media (max-width: 760px) {
    .tool-card.featured { flex-direction: column; grid-column: span 1; }
    .tool-card.featured .card-cover { width: 100%; aspect-ratio: 16/9; }
  }
</style>
