---
interface DownloadLink {
  name: string;
  url: string;
  extractCode?: string;
}
interface Props {
  version: string;
  fileSize: string;
  compatibility: string;
  updatedDate?: Date;
  links: DownloadLink[];
}
const { version, fileSize, compatibility, updatedDate, links } = Astro.props;
const primary = links[0];
const backups = links.slice(1);
const dateStr = updatedDate
  ? updatedDate.toLocaleDateString('zh-CN', { year:'numeric', month:'2-digit', day:'2-digit' }).replace(/\//g,'-')
  : null;
---

<div class="dl-card" id="download">
  <div class="dl-header">
    <div class="dl-icon" aria-hidden="true">📥</div>
    <div>
      <div class="dl-title">下载本工具</div>
      <div class="dl-sub">免费原创 · 持续维护更新</div>
    </div>
  </div>

  <div class="dl-meta">
    <span>版本：<strong>{version}</strong></span>
    <span>大小：<strong>{fileSize}</strong></span>
    <span>兼容：<strong>{compatibility}</strong></span>
    {dateStr && <span>更新：<strong>{dateStr}</strong></span>}
  </div>

  <!-- Primary download -->
  <div class="dl-row">
    <a class="dl-btn primary" href={primary.url} target="_blank" rel="noopener noreferrer">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
        <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/>
        <polyline points="7 10 12 15 17 10"/>
        <line x1="12" y1="15" x2="12" y2="3"/>
      </svg>
      去 {primary.name} 下载
    </a>
    {backups.map(link => (
      <a class="dl-btn secondary" href={link.url} target="_blank" rel="noopener noreferrer">
        备用：{link.name}
      </a>
    ))}
  </div>

  <!-- Extract code -->
  {primary.extractCode && (
    <div class="extract-row">
      <span class="extract-label">提取码：</span>
      <code class="extract-code" id="extract-code">{primary.extractCode}</code>
      <button class="copy-btn" id="copy-btn" data-code={primary.extractCode}>
        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <rect x="9" y="9" width="13" height="13" rx="2"/>
          <path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/>
        </svg>
        复制
      </button>
    </div>
  )}

  <div class="dl-notice">
    ⚠️ 链接失效了？请在下方评论区留言，我会在 24 小时内更新。
  </div>
</div>

<style>
  .dl-card {
    background: linear-gradient(135deg, #F0FDF4 0%, #DCFCE7 100%);
    border: 1.5px solid #86EFAC;
    border-radius: var(--radius);
    padding: 24px 26px;
    margin: 36px 0;
  }
  .dl-header { display: flex; align-items: center; gap: 12px; margin-bottom: 16px; }
  .dl-icon { font-size: 26px; }
  .dl-title { font-family: var(--font-display); font-size: 17px; font-weight: 700; color: #14532D; }
  .dl-sub { font-size: 12px; color: #166534; margin-top: 2px; }
  .dl-meta {
    display: flex; gap: 18px; flex-wrap: wrap;
    margin-bottom: 18px; font-size: 13px; color: #166534;
  }
  .dl-meta strong { font-weight: 600; color: #14532D; }
  .dl-row { display: flex; align-items: center; gap: 10px; flex-wrap: wrap; }
  .dl-btn {
    display: inline-flex; align-items: center; gap: 8px;
    padding: 12px 20px; border-radius: var(--radius-sm);
    font-size: 15px; font-weight: 600; cursor: pointer;
    text-decoration: none; transition: all 0.15s; border: none;
    white-space: nowrap; font-family: var(--font-body);
  }
  .dl-btn.primary { background: var(--green); color: #fff; }
  .dl-btn.primary:hover { background: #15803D; }
  .dl-btn.secondary {
    background: #fff; color: #166534;
    border: 1.5px solid #86EFAC;
  }
  .dl-btn.secondary:hover { background: var(--green-light); }
  .extract-row {
    display: flex; align-items: center; gap: 10px;
    margin-top: 12px; flex-wrap: wrap;
  }
  .extract-label { font-size: 13px; color: #166534; }
  .extract-code {
    font-family: var(--font-mono);
    font-size: 16px; font-weight: 700;
    color: #14532D;
    background: rgba(255,255,255,0.7);
    padding: 4px 12px; border-radius: 6px;
    letter-spacing: 0.1em;
    border: 1px solid #86EFAC;
  }
  .copy-btn {
    display: inline-flex; align-items: center; gap: 5px;
    padding: 5px 12px; border-radius: 6px;
    font-size: 12px; font-weight: 600; cursor: pointer;
    background: #fff; color: #166534;
    border: 1px solid #86EFAC;
    transition: all 0.15s; font-family: var(--font-body);
  }
  .copy-btn:hover { background: var(--green); color: #fff; border-color: var(--green); }
  .copy-btn.copied { background: var(--green); color: #fff; border-color: var(--green); }
  .dl-notice {
    margin-top: 14px; padding-top: 14px;
    border-top: 1px solid #86EFAC;
    font-size: 13px; color: #166534;
  }
</style>

<script>
  document.querySelectorAll('.copy-btn').forEach(btn => {
    btn.addEventListener('click', async () => {
      const code = (btn as HTMLElement).dataset.code ?? '';
      try {
        await navigator.clipboard.writeText(code);
        btn.textContent = '已复制 ✓';
        btn.classList.add('copied');
        setTimeout(() => {
          btn.innerHTML = `<svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/></svg> 复制`;
          btn.classList.remove('copied');
        }, 2000);
      } catch {}
    });
  });
</script>
