---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout
  title="HTML 导入编辑器 — WinTools"
  description="上传 HTML 和图片，压缩图片并保留原有 HTML 样式结构，生成可继续编辑的发布内容。"
>
  <section class="admin-shell">
    <div class="admin-header">
      <div>
        <p class="eyebrow">内容后台</p>
        <h1>HTML 导入编辑器</h1>
      </div>
      <div class="status-pill" id="statusPill">等待导入</div>
    </div>

    <div class="workspace">
      <aside class="panel controls" aria-label="导入设置">
        <label class="field">
          <span>文章 slug</span>
          <input id="slugInput" type="text" placeholder="file-renamer" autocomplete="off" />
        </label>

        <label class="field">
          <span>图片线上目录</span>
          <input id="baseUrlInput" type="url" value="https://winstools.com/images" />
        </label>

        <div class="field">
          <span>HTML 文件</span>
          <label class="file-drop">
            <input id="htmlInput" type="file" accept=".html,.htm,text/html" />
            <strong>选择 HTML</strong>
            <small id="htmlFileName">未选择文件</small>
          </label>
        </div>

        <div class="field">
          <span>图片文件</span>
          <label class="file-drop">
            <input id="imageInput" type="file" accept="image/*" multiple />
            <strong>批量选择图片</strong>
            <small id="imageCount">未选择图片</small>
          </label>
        </div>

        <div class="field">
          <span>图片目录</span>
          <label class="file-drop">
            <input id="directoryInput" type="file" accept="image/*" multiple webkitdirectory />
            <strong>选择图片文件夹</strong>
            <small id="directoryCount">可选</small>
          </label>
        </div>

        <div class="split">
          <label class="field">
            <span>最大宽度</span>
            <input id="maxWidthInput" type="number" value="1400" min="320" max="2560" step="40" />
          </label>
          <label class="field">
            <span>WebP 质量</span>
            <input id="qualityInput" type="number" value="82" min="40" max="95" step="1" />
          </label>
        </div>

        <div class="actions">
          <button class="primary" id="processBtn" type="button">处理 HTML</button>
          <button id="copyBtn" type="button" disabled>复制最终 HTML</button>
          <button id="downloadBtn" type="button" disabled>下载图片包</button>
        </div>

        <div class="metrics" id="metrics">
          <div><strong>0</strong><span>图片</span></div>
          <div><strong>0 KB</strong><span>原始</span></div>
          <div><strong>0 KB</strong><span>压缩后</span></div>
        </div>
      </aside>

      <section class="panel editor-panel">
        <div class="editor-toolbar">
          <div>
            <strong>编辑区域</strong>
            <span>处理完成后可继续改文字和格式</span>
          </div>
          <div class="toolbar-actions">
            <button id="boldBtn" type="button" disabled>B</button>
            <button id="italicBtn" type="button" disabled>I</button>
            <button id="linkBtn" type="button" disabled>链接</button>
          </div>
        </div>
        <iframe id="editorFrame" title="HTML 编辑区域"></iframe>
      </section>
    </div>

    <section class="panel output-panel">
      <div class="output-head">
        <div>
          <strong>处理结果</strong>
          <span id="resultSummary">尚未处理</span>
        </div>
        <button id="refreshHtmlBtn" type="button" disabled>刷新 HTML 输出</button>
      </div>
      <textarea id="htmlOutput" spellcheck="false" placeholder="处理后的 HTML 会显示在这里"></textarea>
    </section>
  </section>
</BaseLayout>

<script is:inline src="https://cdn.jsdelivr.net/npm/jszip@3.10.1/dist/jszip.min.js"></script>

<script>
  const slugInput = document.getElementById('slugInput');
  const baseUrlInput = document.getElementById('baseUrlInput');
  const htmlInput = document.getElementById('htmlInput');
  const imageInput = document.getElementById('imageInput');
  const directoryInput = document.getElementById('directoryInput');
  const htmlFileName = document.getElementById('htmlFileName');
  const imageCount = document.getElementById('imageCount');
  const directoryCount = document.getElementById('directoryCount');
  const maxWidthInput = document.getElementById('maxWidthInput');
  const qualityInput = document.getElementById('qualityInput');
  const processBtn = document.getElementById('processBtn');
  const copyBtn = document.getElementById('copyBtn');
  const downloadBtn = document.getElementById('downloadBtn');
  const refreshHtmlBtn = document.getElementById('refreshHtmlBtn');
  const statusPill = document.getElementById('statusPill');
  const editorFrame = document.getElementById('editorFrame');
  const htmlOutput = document.getElementById('htmlOutput');
  const resultSummary = document.getElementById('resultSummary');
  const metrics = document.getElementById('metrics');
  const boldBtn = document.getElementById('boldBtn');
  const italicBtn = document.getElementById('italicBtn');
  const linkBtn = document.getElementById('linkBtn');

  let processedImages = [];

  htmlInput.addEventListener('change', () => {
    const file = htmlInput.files?.[0];
    htmlFileName.textContent = file ? file.name : '未选择文件';
    if (file && !slugInput.value.trim()) {
      slugInput.value = slugify(file.name.replace(/\.[^.]+$/, ''));
    }
  });

  imageInput.addEventListener('change', () => {
    imageCount.textContent = `${imageInput.files?.length ?? 0} 张图片`;
  });

  directoryInput.addEventListener('change', () => {
    directoryCount.textContent = `${directoryInput.files?.length ?? 0} 个文件`;
  });

  processBtn.addEventListener('click', async () => {
    try {
      setStatus('处理中');
      processBtn.disabled = true;
      const htmlFile = htmlInput.files?.[0];
      if (!htmlFile) throw new Error('请先选择 HTML 文件');

      const slug = slugify(slugInput.value.trim());
      if (!slug) throw new Error('请填写文章 slug');
      slugInput.value = slug;

      const html = await htmlFile.text();
      const imageFiles = [...(imageInput.files ?? []), ...(directoryInput.files ?? [])];
      const imageIndex = indexImages(imageFiles);
      const doc = new DOMParser().parseFromString(html, 'text/html');
      sanitizeDocument(doc);

      const maxWidth = Number(maxWidthInput.value) || 1400;
      const quality = Math.min(Math.max(Number(qualityInput.value) || 82, 40), 95) / 100;
      const baseUrl = baseUrlInput.value.replace(/\/+$/, '');
      const images = Array.from(doc.querySelectorAll('img'));
      processedImages = [];

      let originalBytes = 0;
      let compressedBytes = 0;
      let sequence = 1;

      for (const img of images) {
        const currentSrc = img.getAttribute('src') ?? '';
        const match = findImageFile(currentSrc, imageIndex);
        img.setAttribute('loading', 'lazy');
        img.setAttribute('decoding', 'async');
        if (!img.getAttribute('alt')) {
          img.setAttribute('alt', readableName(currentSrc));
        }
        if (!match) continue;

        const outputName = `${String(sequence).padStart(3, '0')}.webp`;
        const outputPath = `${slug}/${outputName}`;
        const result = await compressImage(match, maxWidth, quality);
        originalBytes += match.size;
        compressedBytes += result.blob.size;
        processedImages.push({
          name: outputName,
          path: outputPath,
          originalName: match.name,
          blob: result.blob,
        });
        img.setAttribute('src', `${baseUrl}/${outputPath}`);
        img.setAttribute('width', String(result.width));
        img.setAttribute('height', String(result.height));
        sequence += 1;
      }

      const finalHtml = serializeBody(doc);
      loadEditor(finalHtml);
      htmlOutput.value = finalHtml;
      updateMetrics(images.length, originalBytes, compressedBytes);
      resultSummary.textContent = `已处理 ${images.length} 个 img，其中 ${processedImages.length} 张已压缩替换`;
      copyBtn.disabled = false;
      downloadBtn.disabled = processedImages.length === 0;
      refreshHtmlBtn.disabled = false;
      setEditorButtons(false);
      setStatus('处理完成');
    } catch (error) {
      setStatus('处理失败');
      alert(error.message);
    } finally {
      processBtn.disabled = false;
    }
  });

  copyBtn.addEventListener('click', async () => {
    refreshOutput();
    await navigator.clipboard.writeText(htmlOutput.value);
    setStatus('已复制');
  });

  refreshHtmlBtn.addEventListener('click', refreshOutput);

  downloadBtn.addEventListener('click', async () => {
    if (!processedImages.length) return;
    setStatus('打包中');
    const zip = await makeImageZip(processedImages);
    const url = URL.createObjectURL(zip);
    const a = document.createElement('a');
    a.href = url;
    a.download = `${slugInput.value || 'images'}-webp-images.zip`;
    a.click();
    URL.revokeObjectURL(url);
    setStatus('图片包已生成');
  });

  boldBtn.addEventListener('click', () => execEditor('bold'));
  italicBtn.addEventListener('click', () => execEditor('italic'));
  linkBtn.addEventListener('click', () => {
    const url = prompt('输入链接 URL');
    if (url) execEditor('createLink', url);
  });

  function setStatus(text) {
    statusPill.textContent = text;
  }

  function setEditorButtons(disabled) {
    boldBtn.disabled = disabled;
    italicBtn.disabled = disabled;
    linkBtn.disabled = disabled;
  }

  function slugify(value) {
    return value
      .toLowerCase()
      .replace(/\.html?$/i, '')
      .replace(/[^a-z0-9]+/g, '-')
      .replace(/^-+|-+$/g, '')
      .slice(0, 80);
  }

  function indexImages(files) {
    const map = new Map();
    files
      .filter(file => file.type.startsWith('image/'))
      .forEach(file => {
        const names = [
          file.name,
          file.webkitRelativePath,
          file.webkitRelativePath?.split('/').pop(),
        ].filter(Boolean);
        names.forEach(name => map.set(normalizePath(name), file));
      });
    return map;
  }

  function normalizePath(path) {
    try {
      path = decodeURIComponent(path);
    } catch {}
    return path.replace(/\\/g, '/').toLowerCase().split('?')[0].split('#')[0];
  }

  function findImageFile(src, imageIndex) {
    const normalized = normalizePath(src);
    const basename = normalized.split('/').pop();
    return imageIndex.get(normalized) || imageIndex.get(basename);
  }

  function readableName(src) {
    const name = normalizePath(src).split('/').pop() || '教程截图';
    return name.replace(/\.[a-z0-9]+$/i, '').replace(/[-_]+/g, ' ');
  }

  function sanitizeDocument(doc) {
    doc.querySelectorAll('script, iframe, object, embed, form').forEach(node => node.remove());
    doc.querySelectorAll('*').forEach(node => {
      [...node.attributes].forEach(attr => {
        const name = attr.name.toLowerCase();
        if (name.startsWith('on')) node.removeAttribute(attr.name);
        if ((name === 'href' || name === 'src') && attr.value.trim().toLowerCase().startsWith('javascript:')) {
          node.removeAttribute(attr.name);
        }
      });
    });
  }

  function serializeBody(doc) {
    return doc.body ? doc.body.innerHTML.trim() : doc.documentElement.innerHTML.trim();
  }

  function loadEditor(html) {
    const editorDoc = `<!doctype html>
      <html>
        <head>
          <meta charset="utf-8">
          <style>
            body { font-family: Arial, "Microsoft YaHei", sans-serif; line-height: 1.75; padding: 24px; color: #111827; }
            img { max-width: 100%; height: auto; }
            table { max-width: 100%; border-collapse: collapse; }
            td, th { border: 1px solid #e5e7eb; padding: 8px; }
            [contenteditable="true"]:focus { outline: none; }
          </style>
        </head>
        <body contenteditable="true">${html}</body>
      </html>`;
    editorFrame.srcdoc = editorDoc;
    editorFrame.addEventListener('load', () => setEditorButtons(false), { once: true });
  }

  function refreshOutput() {
    const doc = editorFrame.contentDocument;
    if (!doc?.body) return;
    htmlOutput.value = doc.body.innerHTML.trim();
    setStatus('HTML 已刷新');
  }

  function execEditor(command, value = null) {
    const doc = editorFrame.contentDocument;
    editorFrame.contentWindow?.focus();
    doc?.execCommand(command, false, value);
    refreshOutput();
  }

  async function compressImage(file, maxWidth, quality) {
    const bitmap = await createImageBitmap(file);
    const scale = Math.min(1, maxWidth / bitmap.width);
    const width = Math.max(1, Math.round(bitmap.width * scale));
    const height = Math.max(1, Math.round(bitmap.height * scale));
    const canvas = document.createElement('canvas');
    canvas.width = width;
    canvas.height = height;
    const ctx = canvas.getContext('2d');
    ctx.drawImage(bitmap, 0, 0, width, height);
    const blob = await new Promise(resolve => canvas.toBlob(resolve, 'image/webp', quality));
    bitmap.close?.();
    return { blob, width, height };
  }

  function updateMetrics(count, originalBytes, compressedBytes) {
    const values = metrics.querySelectorAll('strong');
    values[0].textContent = String(count);
    values[1].textContent = formatBytes(originalBytes);
    values[2].textContent = formatBytes(compressedBytes);
  }

  function formatBytes(bytes) {
    if (!bytes) return '0 KB';
    if (bytes < 1024 * 1024) return `${Math.round(bytes / 1024)} KB`;
    return `${(bytes / 1024 / 1024).toFixed(1)} MB`;
  }

  async function makeImageZip(images) {
    const zip = new JSZip();
    for (const image of images) {
      zip.file(image.path, image.blob);
    }
    return zip.generateAsync({ type: 'blob', compression: 'DEFLATE', compressionOptions: { level: 6 } });
  }
</script>

<style>
  .admin-shell {
    padding: 24px;
    background: var(--bg2);
    min-height: calc(100vh - var(--nav-h));
  }
  .admin-header {
    max-width: 1440px;
    margin: 0 auto 18px;
    display: flex;
    align-items: end;
    justify-content: space-between;
    gap: 16px;
  }
  .eyebrow {
    color: var(--blue);
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 0.06em;
    margin-bottom: 4px;
  }
  .admin-header h1 {
    font-family: var(--font-display);
    font-size: 26px;
    line-height: 1.2;
  }
  .status-pill {
    background: var(--bg);
    border: 1px solid var(--border);
    border-radius: 9999px;
    padding: 6px 12px;
    color: var(--text2);
    font-size: 13px;
    font-weight: 600;
  }
  .workspace {
    max-width: 1440px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 330px minmax(0, 1fr);
    gap: 16px;
    align-items: stretch;
  }
  .panel {
    background: var(--bg);
    border: 1px solid var(--border);
    border-radius: var(--radius-sm);
    box-shadow: var(--shadow-sm);
  }
  .controls {
    padding: 16px;
  }
  .field {
    display: grid;
    gap: 6px;
    margin-bottom: 14px;
  }
  .field span {
    color: var(--text2);
    font-size: 12px;
    font-weight: 700;
  }
  input {
    width: 100%;
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 10px 11px;
    font: inherit;
    color: var(--text);
    background: var(--bg);
  }
  .file-drop {
    display: grid;
    gap: 4px;
    border: 1px dashed #CBD5E1;
    background: var(--bg2);
    border-radius: 8px;
    padding: 13px;
    cursor: pointer;
  }
  .file-drop input {
    position: absolute;
    opacity: 0;
    pointer-events: none;
  }
  .file-drop strong {
    font-size: 14px;
    color: var(--text);
  }
  .file-drop small {
    color: var(--text3);
    font-size: 12px;
    overflow-wrap: anywhere;
  }
  .split {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 10px;
  }
  .actions {
    display: grid;
    gap: 8px;
    margin: 4px 0 16px;
  }
  button {
    border: 1px solid var(--border);
    background: var(--bg);
    color: var(--text);
    border-radius: 8px;
    padding: 10px 12px;
    font: inherit;
    font-weight: 700;
    cursor: pointer;
  }
  button:disabled {
    opacity: 0.5;
    cursor: not-allowed;
  }
  button.primary {
    background: var(--blue);
    border-color: var(--blue);
    color: #fff;
  }
  .metrics {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 8px;
  }
  .metrics div {
    background: var(--bg2);
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 10px;
  }
  .metrics strong {
    display: block;
    font-size: 15px;
    color: var(--text);
  }
  .metrics span {
    color: var(--text3);
    font-size: 11px;
  }
  .editor-panel {
    min-height: 720px;
    display: grid;
    grid-template-rows: auto 1fr;
    overflow: hidden;
  }
  .editor-toolbar,
  .output-head {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 12px;
    padding: 12px 14px;
    border-bottom: 1px solid var(--border);
  }
  .editor-toolbar strong,
  .output-head strong {
    display: block;
    font-size: 14px;
  }
  .editor-toolbar span,
  .output-head span {
    color: var(--text3);
    font-size: 12px;
  }
  .toolbar-actions {
    display: flex;
    gap: 6px;
  }
  .toolbar-actions button {
    min-width: 42px;
    padding: 7px 10px;
  }
  #editorFrame {
    width: 100%;
    height: 100%;
    border: 0;
    background: #fff;
  }
  .output-panel {
    max-width: 1440px;
    margin: 16px auto 0;
    overflow: hidden;
  }
  #htmlOutput {
    width: 100%;
    min-height: 240px;
    border: 0;
    padding: 16px;
    resize: vertical;
    font: 13px/1.6 var(--font-mono);
    color: var(--text);
    background: #F8FAFC;
  }
  @media (max-width: 980px) {
    .workspace { grid-template-columns: 1fr; }
    .editor-panel { min-height: 620px; }
  }
</style>
