---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

const allTools = await getCollection('tools', ({ data }) => !data.draft);
const categories = ['文件处理', '系统优化', '效率工具', '网络工具', '其他'];
const catEmoji: Record<string, string> = {
  '文件处理': '📁',
  '系统优化': '⚙️',
  '效率工具': '⚡',
  '网络工具': '🌐',
  '其他': '🎨',
};
const catDesc: Record<string, string> = {
  '文件处理': '批量改名、格式转换、压缩合并，让文件管理不再费时费力。',
  '系统优化': '清理启动项、释放内存、加速开机，让 Windows 跑得更利索。',
  '效率工具': '剪贴板、快捷启动、自动化，减少重复操作，把时间省下来。',
  '网络工具': '网速监测、连接管理，让网络状态一目了然。',
  '其他': '不好归类但很实用的各种小工具。',
};

const categoryCards = categories.map(category => ({
  name: category,
  emoji: catEmoji[category],
  description: catDesc[category],
  count: allTools.filter(t => t.data.category === category).length,
}));
---

<BaseLayout
  title="工具分类 — WinTools"
  description="按文件处理、系统优化、效率工具、网络工具等分类浏览 WinTools 原创 Windows 小工具。"
>
  <section class="category-hub">
    <div class="container">
      <div class="page-kicker">分类浏览</div>
      <h1>按用途找到需要的 Windows 小工具</h1>
      <p>工具数量会随着文章更新自动统计，空分类也会保留入口，方便后续扩展。</p>
    </div>
  </section>

  <section class="container category-grid-wrap">
    <div class="category-grid">
      {categoryCards.map(category => (
        <a class="category-card" href={`/category/${category.name}`}>
          <span class="category-emoji" aria-hidden="true">{category.emoji}</span>
          <span class="category-main">
            <span class="category-name">{category.name}</span>
            <span class="category-desc">{category.description}</span>
          </span>
          <span class="category-count">{category.count} 款</span>
        </a>
      ))}
    </div>
  </section>
</BaseLayout>

<style>
  .category-hub {
    background: linear-gradient(160deg, #F0F6FF 0%, #ffffff 70%);
    border-bottom: 1px solid var(--border);
    padding: 46px 0 38px;
  }
  .category-hub .container { max-width: 760px; }
  .page-kicker {
    color: var(--blue);
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 0.06em;
    margin-bottom: 10px;
  }
  h1 {
    font-family: var(--font-display);
    font-size: clamp(24px, 4vw, 34px);
    line-height: 1.25;
    margin-bottom: 12px;
  }
  p {
    color: var(--text2);
    font-size: 15px;
    line-height: 1.7;
  }
  .category-grid-wrap { padding: 30px 24px 72px; }
  .category-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    gap: 14px;
  }
  .category-card {
    display: grid;
    grid-template-columns: auto 1fr auto;
    gap: 14px;
    align-items: center;
    padding: 18px;
    background: var(--bg);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    box-shadow: var(--shadow-sm);
    color: inherit;
    text-decoration: none;
    transition: transform 0.18s, box-shadow 0.18s, border-color 0.18s;
  }
  .category-card:hover {
    transform: translateY(-2px);
    box-shadow: var(--shadow-md);
    border-color: var(--blue-mid);
  }
  .category-emoji {
    width: 42px;
    height: 42px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--bg2);
    border: 1px solid var(--border);
    border-radius: 10px;
    font-size: 22px;
  }
  .category-main { min-width: 0; }
  .category-name {
    display: block;
    font-size: 15px;
    font-weight: 700;
    color: var(--text);
    margin-bottom: 3px;
  }
  .category-desc {
    display: block;
    color: var(--text2);
    font-size: 13px;
    line-height: 1.55;
  }
  .category-count {
    color: var(--blue);
    background: var(--blue-light);
    border: 1px solid var(--blue-mid);
    border-radius: 9999px;
    padding: 3px 9px;
    font-size: 12px;
    font-weight: 700;
    white-space: nowrap;
  }
  @media (max-width: 520px) {
    .category-card { grid-template-columns: auto 1fr; }
    .category-count { grid-column: 2; justify-self: start; }
  }
</style>
