---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import ToolCard from '../components/ToolCard.astro';

const allTools = await getCollection('tools', ({ data }) => !data.draft);
allTools.sort((a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf());

const featured = allTools.find(t => t.data.featured) ?? allTools[0];
const rest = allTools.filter(t => t.id !== featured.id);

const categories = ['文件处理', '系统优化', '效率工具', '网络工具', '其他'];
const categoryCounts = categories.map(cat => ({
  name: cat,
  count: allTools.filter(t => t.data.category === cat).length,
}));
---

<BaseLayout
  title="WinTools — 原创 Windows 实用小工具免费下载"
  description={`原创 Windows 实用小工具，共 ${allTools.length} 款，免费分享，附图文教程，开箱即用。`}
>

  <!-- HERO -->
  <section class="hero">
    <div class="container">
      <div class="hero-badge">
        <span class="badge-dot"></span> 持续更新中
      </div>
      <h1 class="hero-title">
        原创 Windows 小工具<br />
        <em>解决每天的电脑小麻烦</em>
      </h1>
      <p class="hero-desc">
        每款工具都是为了解决真实遇到的问题而做，免费分享，附图文使用教程，下载即用。
      </p>
      <div class="hero-stats">
        <div class="stat">
          <span class="stat-num">{allTools.length}</span>
          <span class="stat-label">款工具</span>
        </div>
        <div class="stat-divider"></div>
        <div class="stat">
          <span class="stat-num">持续</span>
          <span class="stat-label">免费更新</span>
        </div>
        <div class="stat-divider"></div>
        <div class="stat">
          <span class="stat-num">0</span>
          <span class="stat-label">广告捆绑</span>
        </div>
      </div>
    </div>
  </section>

  <!-- FILTER TABS -->
  <div class="filter-wrap">
    <div class="container">
      <div class="filter-bar" id="filterBar">
        <button class="filter-tag active" data-cat="all">
          全部 <span class="cnt">{allTools.length}</span>
        </button>
        {categoryCounts.filter(c => c.count > 0).map(c => (
          <button class="filter-tag" data-cat={c.name}>
            {c.name} <span class="cnt">{c.count}</span>
          </button>
        ))}
      </div>
    </div>
  </div>

  <!-- TOOLS GRID -->
  <section class="tools-section">
    <div class="container">
      <div class="section-header">
        <h2 class="section-title">
          全部工具 <span id="gridCount">{allTools.length} 款</span>
        </h2>
      </div>

      <div class="tools-grid" id="toolsGrid">
        <!-- Featured card -->
        <ToolCard
          slug={featured.id}
          title={featured.data.title}
          description={featured.data.description}
          category={featured.data.category}
          cover={featured.data.cover}
          coverEmoji={featured.data.coverEmoji}
          publishDate={featured.data.publishDate}
          featured={true}
          class="fade-in-1"
        />
        <!-- Rest of cards -->
        {rest.map((tool, i) => (
          <ToolCard
            slug={tool.id}
            title={tool.data.title}
            description={tool.data.description}
            category={tool.data.category}
            cover={tool.data.cover}
            coverEmoji={tool.data.coverEmoji}
            publishDate={tool.data.publishDate}
            class={`fade-in-${Math.min(i + 2, 6)}`}
          />
        ))}
      </div>

      <!-- Empty state -->
      <div class="empty-state" id="emptyState" hidden>
        <div class="empty-icon">🔍</div>
        <p>该分类暂无工具，敬请期待</p>
      </div>
    </div>
  </section>

</BaseLayout>

<style>
  /* HERO */
  .hero {
    background: linear-gradient(160deg, #F0F6FF 0%, #ffffff 65%);
    border-bottom: 1px solid var(--border);
    padding: 56px 0 48px;
    text-align: center;
  }
  .hero-badge {
    display: inline-flex; align-items: center; gap: 6px;
    background: var(--blue-light); border: 1px solid var(--blue-mid);
    color: var(--blue); font-size: 12px; font-weight: 600;
    padding: 4px 12px; border-radius: 9999px; margin-bottom: 20px;
  }
  .badge-dot {
    width: 7px; height: 7px; border-radius: 50%;
    background: var(--blue);
    animation: pulse 2s infinite;
  }
  @keyframes pulse { 0%,100%{opacity:1} 50%{opacity:0.35} }
  .hero-title {
    font-family: var(--font-display);
    font-size: clamp(24px, 4vw, 38px);
    font-weight: 700; line-height: 1.25;
    letter-spacing: -0.02em;
    margin-bottom: 14px;
  }
  .hero-title em { font-style: normal; color: var(--blue); }
  .hero-desc {
    font-size: 16px; color: var(--text2);
    max-width: 460px; margin: 0 auto 28px; line-height: 1.7;
  }
  .hero-stats {
    display: flex; align-items: center;
    justify-content: center; gap: 28px;
  }
  .stat { text-align: center; }
  .stat-num {
    display: block;
    font-family: var(--font-display);
    font-size: 22px; font-weight: 700; color: var(--text);
  }
  .stat-label { font-size: 12px; color: var(--text3); margin-top: 2px; }
  .stat-divider { width: 1px; height: 30px; background: var(--border); }

  /* FILTERS */
  .filter-wrap {
    border-bottom: 1px solid var(--border);
    background: var(--bg);
    position: sticky; top: var(--nav-h); z-index: 50;
  }
  .filter-bar {
    display: flex; gap: 8px; flex-wrap: wrap;
    padding: 12px 0;
  }
  .filter-tag {
    display: inline-flex; align-items: center; gap: 5px;
    padding: 5px 14px; border-radius: 9999px;
    font-size: 13px; font-weight: 500;
    cursor: pointer; transition: all 0.15s;
    border: 1px solid var(--border);
    background: var(--bg); color: var(--text2);
    font-family: var(--font-body);
  }
  .filter-tag:hover { border-color: var(--blue); color: var(--blue); background: var(--blue-light); }
  .filter-tag.active { background: var(--blue); border-color: var(--blue); color: #fff; }
  .filter-tag .cnt {
    font-size: 11px; padding: 0 5px;
    background: rgba(0,0,0,0.08); border-radius: 9999px;
  }
  .filter-tag.active .cnt { background: rgba(255,255,255,0.25); }

  /* TOOLS GRID */
  .tools-section { padding: 28px 0 72px; }
  .section-header {
    display: flex; align-items: center;
    justify-content: space-between; margin-bottom: 20px;
  }
  .section-title {
    font-family: var(--font-display);
    font-size: 16px; font-weight: 600;
  }
  .section-title span { color: var(--text3); font-weight: 400; font-size: 14px; margin-left: 6px; }
  .tools-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(290px, 1fr));
    gap: 20px;
  }
  .empty-state {
    text-align: center; padding: 60px 0;
    color: var(--text3); font-size: 15px;
  }
  .empty-icon { font-size: 40px; margin-bottom: 12px; }

  @media (max-width: 600px) {
    .tools-grid { grid-template-columns: 1fr; }
    .hero-stats { gap: 16px; }
  }
</style>

<script>
  const tags = document.querySelectorAll<HTMLButtonElement>('.filter-tag');
  const grid = document.getElementById('toolsGrid');
  const countEl = document.getElementById('gridCount');
  const empty = document.getElementById('emptyState');
  const cards = grid?.querySelectorAll<HTMLAnchorElement>('.tool-card');

  tags.forEach(tag => {
    tag.addEventListener('click', () => {
      tags.forEach(t => t.classList.remove('active'));
      tag.classList.add('active');
      const cat = tag.dataset.cat;
      let visible = 0;
      cards?.forEach(card => {
        const cardCat = card.querySelector('.card-cat')?.textContent?.trim();
        const show = cat === 'all' || cardCat === cat;
        card.style.display = show ? '' : 'none';
        if (show) visible++;
      });
      if (countEl) countEl.textContent = `${visible} 款`;
      if (empty) empty.hidden = visible > 0;
    });
  });
</script>
